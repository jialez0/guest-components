{
  "openapi": "3.1.0",
  "info": {
    "title": "CoCo Restful API",
    "description": "HTTP based API for CoCo containers to get resource/evidence/token from confidential-data-hub and attestation-agent.",
    "contact": {
      "name": "The Confidential Container Authors"
    },
    "license": {
      "name": "Apache-2.0",
      "identifier": "Apache-2.0"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8006",
      "description": "CoCo Restful API"
    }
  ],
  "paths": {
    "/aa/evidence": {
      "get": {
        "tags": [],
        "operationId": "_evidence",
        "parameters": [
          {
            "name": "runtime_data",
            "in": "query",
            "description": "Runtime Data",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "success response",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string"
                },
                "example": {
                  "report_data": "eHh4eA==",
                  "svn": "1"
                }
              }
            }
          },
          "400": {
            "description": "bad request for invalid query param"
          },
          "403": {
            "description": "forbid external access"
          },
          "404": {
            "description": "resource not found"
          },
          "405": {
            "description": "only Get method allowed"
          }
        }
      }
    },
    "/aa/token": {
      "get": {
        "tags": [],
        "operationId": "_token",
        "parameters": [
          {
            "name": "token_type",
            "in": "query",
            "description": "Token Type",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "success response",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string"
                },
                "example": {
                  "tee_keypair": "-----BEGIN RSA... ",
                  "token": "eyJhbGciOiJFUzI1NiI..."
                }
              }
            }
          },
          "400": {
            "description": "bad request for invalid token type"
          },
          "403": {
            "description": "forbid external access"
          },
          "404": {
            "description": "resource not found"
          },
          "405": {
            "description": "only Get method allowed"
          }
        }
      }
    },
    "/cdh/resource-injection/commit/{repository}/{type}/{tag}": {
      "post": {
        "tags": [],
        "operationId": "_resource_injection_commit",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "commit injection response"
          },
          "403": {
            "description": "forbid external access"
          },
          "404": {
            "description": "resource not found"
          },
          "405": {
            "description": "only POST method allowed"
          }
        }
      }
    },
    "/cdh/resource-injection/prepare/{repository}/{type}/{tag}": {
      "post": {
        "tags": [],
        "operationId": "_resource_injection_prepare",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "prepare injection response",
            "content": {
              "application/json": {
                "schema": {},
                "example": {
                  "evidence": "base64-encoded-evidence",
                  "nonce": "nonce-from-verifier",
                  "session_id": "inject-session-id",
                  "tee_pubkey": {
                    "alg": "ECDH-ES+A256KW",
                    "crv": "P-256",
                    "kty": "EC",
                    "x": "....",
                    "y": "...."
                  }
                }
              }
            }
          },
          "403": {
            "description": "forbid external access"
          },
          "404": {
            "description": "resource not found"
          },
          "405": {
            "description": "only POST method allowed"
          }
        }
      }
    },
    "/cdh/resource/{repository}/{type}/{tag}": {
      "get": {
        "tags": [],
        "operationId": "_resource",
        "responses": {
          "200": {
            "description": "success response",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string"
                },
                "example": {
                  "123456": "value"
                }
              }
            }
          },
          "403": {
            "description": "forbid external access"
          },
          "404": {
            "description": "resource not found"
          },
          "405": {
            "description": "only Get method allowed"
          }
        }
      }
    }
  },
  "components": {}
}